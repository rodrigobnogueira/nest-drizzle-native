{
  "name": "nest-drizzle-native-sample-17-drizzle-kit-migrations",
  "version": "0.0.0",
  "private": true,
  "description": "Sample 17 - drizzle-kit migrations",
  "license": "MIT",
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "ts-node --transpile-only scripts/smoke.ts",
    "test": "npm run typecheck && npm run smoke",
    "start": "ts-node --transpile-only src/main.ts"
  },
  "scarfSettings": {
    "enabled": false
  },
  "dependencies": {
    "@nestjs/common": "11.1.21",
    "@nestjs/core": "11.1.21",
    "@nestjs/platform-express": "11.1.21",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "nest-drizzle-native": "0.2.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "drizzle-kit": "^0.31.10",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
