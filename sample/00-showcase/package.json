{
  "name": "nest-drizzle-native-showcase",
  "version": "0.0.0",
  "private": true,
  "description": "Sample 00 - full Nest-native Drizzle showcase",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "ts-node --transpile-only scripts/smoke.ts",
    "test": "npm run typecheck && npm run smoke",
    "start": "ts-node --transpile-only src/main.ts",
    "start:fastify": "ts-node --transpile-only src/main.fastify.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs-cls/transactional-adapter-drizzle-orm": "^1.2.3",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.4.2",
    "class-transformer": "0.5.1",
    "class-validator": "^0.14.4",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "nest-drizzle-native": "0.2.0",
    "nestjs-cls": "^6.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
